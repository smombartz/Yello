# Yello Electron App Configuration
# Copy this to ~/.config/Yello/.env and fill in your values

# Google OAuth Credentials
# Get these from: https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3456/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# HERE.com Geocoding API (optional)
# Get key from: https://developer.here.com/
# Free tier: 250,000 requests/month
HERE_API_KEY=your_here_api_key_here

# Apify LinkedIn Enrichment (optional)
# Get token from: https://apify.com/
APIFY_API_TOKEN=your_apify_token_here
