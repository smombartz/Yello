# Server Configuration
PORT=3456
NODE_ENV=development

# Database (multi-tenant: shared auth DB + per-user contact DBs)
AUTH_DATABASE_PATH=./data/auth.db
USER_DATA_PATH=./data/users

# Legacy (only needed for migration from single-tenant)
# DATABASE_PATH=./data/contacts.db
# PHOTOS_PATH=./data/photos

# Google OAuth2 Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com
# 1. Create a new project (or use existing)
# 2. Go to APIs & Services > Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add authorized redirect URI: http://localhost:3456/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# App URL (used for OAuth callback)
APP_URL=http://localhost:3456

# Session Secret (generate a random 32+ character string)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_random_string_in_production

# HERE.com Geocoding API
# Get a free API key from: https://developer.here.com/
# 1. Create a HERE account
# 2. Create a new project
# 3. Generate an API key
# Free tier includes 250,000 requests/month
HERE_API_KEY=your_here_api_key_here
